   "source": [
    "def count_long_words(words):\n",
    "    count=0\n",
    "    for w in words:\n",
    "        if len(w)>=5:\n",
    "            count+=1\n",
    "    return count\n",
    "\n",
    "#呼び出し\n",
    "words=[\"apple\",\"cat\",\"banana\",\"dog\",\"python\"]\n",
    "print(count_long_words(words))\n"
   ]
  }
